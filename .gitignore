# Environment and secrets
.env
*.pem
venv/

# Python
__pycache__/
*.pyc
*.pyo
.cache/
*.egg-info/
dist/
.pytest_cache/

# Generated data artifacts
data/*.csv
data/*.parquet
signals/*.json
# Keep sample data so first-clone has something to work with
!data/sample_*.csv

# Models
models/saved/*.json
models/saved/*.pkl
!models/saved/.gitkeep
# Keep the fitted calibration curve as a research artifact (no secrets, just
# the isotonic curve coefficients fitted on public Kalshi settlement data)
!models/saved/win_prob_calibration.json

# Node
dashboard/node_modules/
dashboard/.next/

# OS
.DS_Store
Thumbs.db
NUL

# IDE
.vscode/
.idea/
data/*.db
data/last_refresh.json
data/strategies.db
data/api_audit.json
data/liquidity_report.json

# Runtime logs (server output, debug traces) — never commit these
logs/
*.log

# Jupyter notebook checkpoints
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/
