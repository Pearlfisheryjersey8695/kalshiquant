# Kalshi API credentials
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

KALSHI_API_KEY=your-api-key-here
KALSHI_BASE_URL=https://trading-api.kalshi.com
PRIVATE_KEY_PATH=private_key.pem

# Optional: Anthropic API key for AI sentiment scoring
# If not set, sentiment engine uses consensus data only (no Claude API calls)
ANTHROPIC_API_KEY=
