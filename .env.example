# Kalshi API credentials
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

KALSHI_API_KEY=your-api-key-here
KALSHI_BASE_URL=https://api.elections.kalshi.com
PRIVATE_KEY_PATH=private_key.pem

# External Data Feeds (optional - significantly improves signal quality)
FRED_API_KEY=  # Free at https://fred.stlouisfed.org/docs/api/api_key.html

# Execution Mode
LIVE_TRADING=false  # ONLY set true after /api/calibration shows go_live_ready=true

# Optional: Anthropic API key for AI sentiment scoring
ANTHROPIC_API_KEY=
